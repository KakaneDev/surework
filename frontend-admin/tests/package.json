{
  "name": "surework-admin-e2e-tests",
  "version": "1.0.0",
  "description": "E2E tests for SureWork Admin Dashboard",
  "scripts": {
    "test": "npx playwright test",
    "test:ui": "npx playwright test --ui",
    "test:debug": "npx playwright test --debug",
    "test:smoke": "npx playwright test --project=smoke",
    "test:chrome": "npx playwright test --project=chromium",
    "test:firefox": "npx playwright test --project=firefox",
    "test:mobile": "npx playwright test --project=mobile-chrome",
    "test:headed": "npx playwright test --headed",
    "test:report": "npx playwright show-report reports/html",
    "test:ci": "npx playwright test --reporter=github,json,junit"
  },
  "devDependencies": {
    "@playwright/test": "^1.41.0",
    "@types/node": "^20.10.0"
  }
}
