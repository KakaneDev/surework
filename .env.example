# SureWork ERP Platform - Environment Configuration
# Copy this file to .env and update values for your environment

# ==================== Database ====================
POSTGRES_USER=surework
POSTGRES_PASSWORD=surework
POSTGRES_DB=surework

# ==================== JWT Configuration ====================
# IMPORTANT: Change this in production!
JWT_SECRET=surework-jwt-secret-key-change-in-production-minimum-256-bits

# ==================== Redis ====================
REDIS_HOST=localhost
REDIS_PORT=6379

# ==================== Kafka ====================
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ==================== MinIO (S3-compatible storage) ====================
MINIO_ROOT_USER=surework
MINIO_ROOT_PASSWORD=surework123
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=surework
S3_SECRET_KEY=surework123
S3_BUCKET=surework-documents

# ==================== Eureka ====================
EUREKA_URI=http://localhost:8761/eureka
EUREKA_USERNAME=admin
EUREKA_PASSWORD=surework

# ==================== Service Ports ====================
GATEWAY_PORT=8080
EUREKA_PORT=8761
ADMIN_PORT=8088
EMPLOYEE_PORT=8081
LEAVE_PORT=8082
PAYROLL_PORT=8083
ACCOUNTING_PORT=8084
RECRUITMENT_PORT=8085
TIME_PORT=8086
REPORTING_PORT=8087
DOCUMENT_PORT=8089

# ==================== Email Configuration ====================
# For notifications (leave, payroll, recruitment)
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=noreply@surework.co.za
MAIL_PASSWORD=your-mail-password
MAIL_FROM=SureWork ERP <noreply@surework.co.za>

# ==================== South African Statutory ====================
# SARS eFiling credentials (for automated submissions)
SARS_EFILING_USER=
SARS_EFILING_PASSWORD=

# UIF Integration
UIF_API_KEY=
UIF_API_URL=https://uif.gov.za/api

# ==================== Application ====================
SPRING_PROFILES_ACTIVE=development
LOG_LEVEL=DEBUG

# ==================== Security ====================
# Password policy
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGIT=true
PASSWORD_REQUIRE_SPECIAL=true
PASSWORD_HISTORY_COUNT=5
PASSWORD_EXPIRY_DAYS=90
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# Session
SESSION_TIMEOUT_MINUTES=60
REMEMBER_ME_DAYS=7
